FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=en_US.UTF-8

# Базовая среда разработки
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake git wget curl python3 python3-pip \
    openssh-client gdb gdbserver \
    # Для ESP32
    gcc-riscv64-unknown-elf gcc-arm-none-eabi \
    # Для кросс-компиляции под RPi (ARM64)
    gcc-aarch64-linux-gnu g++-aarch64-linux-gnu \
    # Утилиты
    vim htop tmux \
    && rm -rf /var/lib/apt/lists/*

# Установка ESP-IDF
ENV IDF_TOOLS_PATH=/opt/esp/.espressif \
    IDF_PATH=/opt/esp/idf \
    IDF_VERSION=v5.3.2

RUN git clone --depth 1 --branch $IDF_VERSION https://github.com/espressif/esp-idf.git /opt/esp/idf && \
    cd /opt/esp/idf && \
    ./install.sh esp32 && \
    rm -rf /opt/esp/idf/.git

# Создание пользователя
RUN useradd -m -u 1000 -s /bin/bash dev && \
    echo 'source /opt/esp/idf/export.sh' >> /home/dev/.bashrc

USER dev
WORKDIR /workspace

