 */
enum class EbyteStatus {
    SUCCESS,                        // Успешное выполнение
    ERROR_INIT,                     // Ошибка инициализации
    ERROR_SEND,                     // Ошибка отправки
    ERROR_RECEIVE,                  // Ошибка приема
